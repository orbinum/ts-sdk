{
  "name": "@orbinum/sdk",
  "version": "0.7.8",
  "description": "Official TypeScript SDK for Orbinum.",
  "author": "Orbinum",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run typecheck:all && npm run lint && npm run format:check && npm run build && npm run test",
    "clean": "rm -rf dist node_modules package-lock.json yarn.lock pnpm-lock.yaml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orbinum/ts-sdk.git"
  },
  "keywords": [
    "orbinum",
    "sdk",
    "typescript",
    "privacy",
    "blockchain"
  ],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/orbinum/ts-sdk/issues"
  },
  "homepage": "https://github.com/orbinum/ts-sdk#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.8.0",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@orbinum/proof-generator": "3.7.0",
    "@polkadot-api/metadata-builders": "0.14.2",
    "@polkadot-api/substrate-bindings": "0.20.2",
    "@polkadot-api/tx-utils": "0.3.2",
    "@polkadot/util-crypto": "14.0.3",
    "@scure/base": "2.2.0",
    "@zk-kit/baby-jubjub": "1.0.3",
    "polkadot-api": "2.1.3",
    "poseidon-lite": "0.3.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
